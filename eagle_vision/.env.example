# ═══════════════════════════════════════════════════════════
# Eagle Vision — Configuration (template)
# Copy this file to `.env` and adjust the values for your setup.
# ═══════════════════════════════════════════════════════════

# ── Video Input ──────────────────────────────────────────
VIDEO_SOURCE=input/sample.mp4

# ── YOLO Detection ──────────────────────────────────────
YOLO_MODEL=models/best.pt
YOLO_DEVICE=cuda
YOLO_CONFIDENCE=0.6
YOLO_IOU_THRESHOLD=0.5

# ── Tracking ─────────────────────────────────────────────
TRACK_LOST_TIMEOUT=30.0
TRACK_IOU_MATCH_THRESHOLD=0.3

# ── Optical Flow & Motion ────────────────────────────────
FLOW_MAGNITUDE_THRESHOLD=2.0
UPPER_ROI_RATIO=0.4
LOWER_ROI_RATIO=0.6
HORIZONTAL_FLOW_RATIO=0.6

# ── Activity Classification ─────────────────────────────
ACTIVE_FLOW_THRESHOLD=2.0
DIGGING_DOWNWARD_THRESHOLD=-0.5
DUMPING_UPWARD_THRESHOLD=0.5
SWINGING_HORIZONTAL_THRESHOLD=0.6

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=equipment-events
KAFKA_PUBLISH_INTERVAL=10

# ── TimescaleDB ──────────────────────────────────────────
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=eagle_vision
TIMESCALE_USER=your_user_here
TIMESCALE_PASSWORD=your_password_here

# ── API Server ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit UI ─────────────────────────────────────────
STREAMLIT_API_URL=ws://localhost:8000/ws
STREAMLIT_REST_URL=http://localhost:8000
